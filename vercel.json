{
  "rewrites": [
    {
      "source": "/api/stats/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/auth/token",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/auth/logout",
      "destination": "/api/index.py"
    },
    {
      "source": "/health/:path*",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/*.py": {
      "maxDuration": 10
    }
  }
}