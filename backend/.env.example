# backend/.env.example
# Copy this to .env and fill in the values
#
# For Vercel deployment, set these in the Vercel Dashboard → Settings → Environment Variables.
# Vercel automatically sets VERCEL=1 so the app detects serverless mode.

# === APP ===
APP_NAME=VISUALify API
DEBUG=true
ENVIRONMENT=development
# ENVIRONMENT=production   # ← use this on Vercel

# === DATABASE ===
# Local development (use docker-compose up)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visualify
# Production: use Neon or Supabase pooled connection string
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz.us-east-2.aws.neon.tech/visualify?sslmode=require

# === REDIS ===
REDIS_URL=redis://localhost:6379
# Production: use Upstash Redis (or leave empty to disable caching)
# REDIS_URL=rediss://default:token@us1-xyz.upstash.io:6379

# === SPOTIFY OAUTH ===
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback/spotify
# Production: SPOTIFY_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback/spotify

# === SECURITY: Encryption Key ===
# CRITICAL: Generate a new key for production!
# Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === SECURITY: JWT Secret ===
# CRITICAL: Generate a new secret for production!
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# === FRONTEND ===
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-app.vercel.app
