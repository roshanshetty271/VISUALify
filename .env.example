# VISUALify — Environment Variables
# For local dev, copy to .env.local
# For Vercel, set these in Dashboard → Settings → Environment Variables

# ============================================================
# FRONTEND (Next.js — prefixed with NEXT_PUBLIC_ where needed)
# ============================================================

# Spotify OAuth (used by NextAuth)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://127.0.0.1:3000
# Production: NEXTAUTH_URL=https://your-app.vercel.app

# Backend API URL (public, used by browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: NEXT_PUBLIC_API_URL=https://your-app.vercel.app

# WebSocket URL — leave UNSET on Vercel to activate polling mode
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Production: do NOT set this variable (enables client-side polling fallback)

# ============================================================
# BACKEND (FastAPI — used by api/index.py via backend/app/config.py)
# ============================================================

# Database (PostgreSQL with asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visualify
# Production: use Neon or Supabase pooled connection string
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz.us-east-2.aws.neon.tech/visualify?sslmode=require

# Redis (optional — caching and rate-limit locking)
REDIS_URL=redis://localhost:6379
# Production: use Upstash Redis or leave empty to disable
# REDIS_URL=rediss://default:token@us1-xyz.upstash.io:6379

# Spotify OAuth (same values as frontend)
# SPOTIFY_CLIENT_ID and SPOTIFY_CLIENT_SECRET are shared
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback/spotify
# Production: SPOTIFY_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback/spotify

# Encryption key for Spotify token storage
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT secret for backend API tokens
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-app.vercel.app

# App settings
ENVIRONMENT=development
# Production: ENVIRONMENT=production
DEBUG=true
# Production: DEBUG=false
