# Zustand Rules

## Store Creation

### Basic Store
```tsx
// src/stores/usePlayerStore.ts
import { create } from 'zustand';
import type { Track, AudioFeatures } from '@/types';

interface PlayerState {
  // State
  currentTrack: Track | null;
  audioFeatures: AudioFeatures | null;
  recentTracks: Track[];
  isPlaying: boolean;
  isLoading: boolean;
  error: string | null;
}

interface PlayerActions {
  setCurrentTrack: (track: Track | null) => void;
  setAudioFeatures: (features: AudioFeatures | null) => void;
  setRecentTracks: (tracks: Track[]) => void;
  setIsPlaying: (playing: boolean) => void;
  setIsLoading: (loading: boolean) => void;
  setError: (error: string | null) => void;
  reset: () => void;
}

const initialState: PlayerState = {
  currentTrack: null,
  audioFeatures: null,
  recentTracks: [],
  isPlaying: false,
  isLoading: true,
  error: null,
};

export const usePlayerStore = create<PlayerState & PlayerActions>((set) => ({
  ...initialState,

  setCurrentTrack: (track) => set({ currentTrack: track }),
  setAudioFeatures: (features) => set({ audioFeatures: features }),
  setRecentTracks: (tracks) => set({ recentTracks: tracks }),
  setIsPlaying: (playing) => set({ isPlaying: playing }),
  setIsLoading: (loading) => set({ isLoading: loading }),
  setError: (error) => set({ error }),
  reset: () => set(initialState),
}));
```

## Selectors (CRITICAL for Performance)

### Always Use Selectors
```tsx
// ✅ Good - only re-renders when currentTrack changes
const currentTrack = usePlayerStore((state) => state.currentTrack);

// ❌ Bad - re-renders on ANY state change
const { currentTrack } = usePlayerStore();
const store = usePlayerStore();
```

### Custom Selector Hooks
```tsx
// src/stores/usePlayerStore.ts (add at bottom)

// Export selector hooks for common patterns
export const useCurrentTrack = () => 
  usePlayerStore((state) => state.currentTrack);

export const useAudioFeatures = () => 
  usePlayerStore((state) => state.audioFeatures);

export const useIsPlaying = () => 
  usePlayerStore((state) => state.isPlaying);

export const useRecentTracks = () => 
  usePlayerStore((state) => state.recentTracks);

export const usePlayerError = () => 
  usePlayerStore((state) => state.error);

export const usePlayerActions = () => 
  usePlayerStore((state) => ({
    setCurrentTrack: state.setCurrentTrack,
    setAudioFeatures: state.setAudioFeatures,
    setRecentTracks: state.setRecentTracks,
    setIsPlaying: state.setIsPlaying,
    setError: state.setError,
    reset: state.reset,
  }));
```

### Derived Selectors
```tsx
// For computed values
export const useHasTrack = () => 
  usePlayerStore((state) => state.currentTrack !== null);

export const useTrackEnergy = () =>
  usePlayerStore((state) => state.audioFeatures?.energy ?? 0.5);
```

## Multiple Values with Shallow Compare

```tsx
import { useShallow } from 'zustand/react/shallow';

// When you need multiple values
const { currentTrack, isPlaying } = usePlayerStore(
  useShallow((state) => ({
    currentTrack: state.currentTrack,
    isPlaying: state.isPlaying,
  }))
);
```

## Async Actions

```tsx
// Actions can be async - Zustand doesn't care
const usePlayerStore = create<PlayerStore>((set, get) => ({
  // ... state ...

  fetchNowPlaying: async (accessToken: string) => {
    set({ isLoading: true, error: null });
    
    try {
      const response = await fetch('https://api.spotify.com/v1/me/player/currently-playing', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      
      if (!response.ok) {
        throw new Error('Failed to fetch');
      }
      
      const data = await response.json();
      set({ 
        currentTrack: data.item,
        isPlaying: data.is_playing,
        isLoading: false,
      });
    } catch (error) {
      set({ 
        error: error instanceof Error ? error.message : 'Unknown error',
        isLoading: false,
      });
    }
  },
}));
```

## Accessing State Outside React

```tsx
// Get current state
const currentTrack = usePlayerStore.getState().currentTrack;

// Subscribe to changes
const unsubscribe = usePlayerStore.subscribe(
  (state) => console.log('State changed:', state)
);

// Update state
usePlayerStore.setState({ isPlaying: true });

// Useful in non-React contexts (API clients, utilities)
```

## Persist Middleware (Optional)

```tsx
import { create } from 'zustand';
import { persist } from 'zustand/middleware';

export const useVisualizerStore = create<VisualizerStore>()(
  persist(
    (set) => ({
      mode: 'galaxy',
      setMode: (mode) => set({ mode }),
    }),
    {
      name: 'visualizer-storage', // localStorage key
      partialize: (state) => ({ mode: state.mode }), // Only persist mode
    }
  )
);
```

## DevTools Middleware

```tsx
import { create } from 'zustand';
import { devtools } from 'zustand/middleware';

export const usePlayerStore = create<PlayerStore>()(
  devtools(
    (set) => ({
      // ... store implementation
    }),
    { name: 'PlayerStore' }
  )
);
```

## Store Organization

### Separate Stores by Domain
```
src/stores/
├── usePlayerStore.ts      # Player/track state
├── useVisualizerStore.ts  # Visualization settings
├── useUIStore.ts          # UI state (modals, etc.)
└── index.ts               # Barrel export
```

### Index Export
```tsx
// src/stores/index.ts
export { usePlayerStore, useCurrentTrack, useAudioFeatures } from './usePlayerStore';
export { useVisualizerStore, useVisualizationMode } from './useVisualizerStore';
```

## Common Mistakes

❌ Not using selectors (causes unnecessary re-renders)
```tsx
// BAD
const store = usePlayerStore();

// GOOD
const track = usePlayerStore((s) => s.currentTrack);
```

❌ Mutating state directly
```tsx
// BAD
state.tracks.push(newTrack);

// GOOD
set({ tracks: [...state.tracks, newTrack] });
```

❌ Creating store inside component
```tsx
// BAD - creates new store every render
function Component() {
  const useStore = create(...);
}

// GOOD - create outside component
const useStore = create(...);
function Component() {
  const value = useStore((s) => s.value);
}
```

❌ Using Zustand in Server Components
```tsx
// Server Components can't use hooks!
// Zustand is client-only
```
